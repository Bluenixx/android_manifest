<manifest>

  <remote  name="github"
           fetch="https://github.com/" />

  <remote  name="lineage"
           fetch="https://github.com/LineageOS"
           revision="refs/heads/lineage-23.2" />

  <remote  name="bluenix"
           fetch="https://github.com/Bluenixx"
           revision="refs/heads/lineage-23.2" />

